@{
    ViewData["Title"] = "Home - MediCare Healthcare System";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        .hero-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 80px 0;
            text-align: center;
        }
        .hero-section h1 {
            font-size: 3rem;
            margin-bottom: 20px;
        }
        .feature-card {
            border: 1px solid #ddd;
            border-radius: 10px;
            padding: 30px;
            margin: 20px 0;
            text-align: center;
            transition: transform 0.3s;
        }
        .feature-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        .btn-custom {
            padding: 12px 30px;
            font-size: 1.1rem;
            border-radius: 25px;
            margin: 10px;
        }
        .stats-section {
            background: #f8f9fa;
            padding: 50px 0;
            text-align: center;
        }
        .stat-box {
            padding: 20px;
        }
        .stat-box h3 {
            font-size: 2.5rem;
            color: #667eea;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>

    <!-- Hero Section -->
    <div class="hero-section">
        <div class="container">
            <h1>Welcome to MediCare Healthcare System</h1>
            <p class="lead">Your Health, Our Priority - Book appointments with top doctors online</p>
            <div>
                <a href="@Url.Action("SearchDoctors", "Patient")" class="btn btn-light btn-custom">Find a Doctor</a>
                <a href="@Url.Action("RegisterPatient", "Account")" class="btn btn-outline-light btn-custom">Register Now</a>
            </div>
        </div>
    </div>

    <!-- Statistics Section -->
    <div class="stats-section">
        <div class="container">
            <div class="row">
                <div class="col-md-4 stat-box">
                    <h3>@ViewBag.DoctorCount+</h3>
                    <p>Expert Doctors</p>
                </div>
                <div class="col-md-4 stat-box">
                    <h3>@ViewBag.Specialties?.Count+</h3>
                    <p>Specialties</p>
                </div>
                <div class="col-md-4 stat-box">
                    <h3>24/7</h3>
                    <p>Online Support</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Features Section -->
    <div class="container my-5">
        <div class="row">
            <div class="col-md-12 text-center mb-4">
                <h2>Why Choose MediCare?</h2>
            </div>
        </div>
        <div class="row">
            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-calendar-check" style="font-size: 3rem; color: #667eea;"></i>
                    <h4>Easy Appointment Booking</h4>
                    <p>Book appointments with your preferred doctors in just a few clicks</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-hospital" style="font-size: 3rem; color: #667eea;"></i>
                    <h4>Expert Doctors</h4>
                    <p>Access to qualified specialists in various medical fields</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-credit-card" style="font-size: 3rem; color: #667eea;"></i>
                    <h4>Secure Online Payment</h4>
                    <p>Pay consultation fees securely through our platform</p>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-file-medical" style="font-size: 3rem; color: #667eea;"></i>
                    <h4>Medical Records</h4>
                    <p>Access your medical history and prescriptions anytime</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-clock-history" style="font-size: 3rem; color: #667eea;"></i>
                    <h4>Flexible Scheduling</h4>
                    <p>Choose appointment slots that fit your schedule</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-star-fill" style="font-size: 3rem; color: #667eea;"></i>
                    <h4>Patient Reviews</h4>
                    <p>Read reviews from other patients before booking</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Specialties Section -->
    <div class="container my-5">
        <div class="row">
            <div class="col-md-12 text-center mb-4">
                <h2>Our Medical Specialties</h2>
            </div>
        </div>
        <div class="row">
            @if (ViewBag.Specialties != null)
            {
                @foreach (var specialty in ViewBag.Specialties)
                {
                    <div class="col-md-3 mb-3">
                        <div class="card">
                            <div class="card-body text-center">
                                <h5>@specialty</h5>
                                <a href="@Url.Action("SearchDoctors", "Patient", new { specialty = specialty })" class="btn btn-sm btn-primary">View Doctors</a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Login Options Section -->
    <div class="container my-5">
        <div class="row">
            <div class="col-md-12 text-center mb-4">
                <h2>Sign In</h2>
            </div>
        </div>
        <div class="row justify-content-center">
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body text-center">
                        <i class="bi bi-person-badge" style="font-size: 3rem; color: #667eea;"></i>
                        <h5 class="mt-3">Admin</h5>
                        <a href="@Url.Action("Login", "Account", new { userType = "admin" })" class="btn btn-primary">Admin Login</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body text-center">
                        <i class="bi bi-person-heart" style="font-size: 3rem; color: #667eea;"></i>
                        <h5 class="mt-3">Doctor</h5>
                        <a href="@Url.Action("Login", "Account", new { userType = "doctor" })" class="btn btn-primary">Doctor Login</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body text-center">
                        <i class="bi bi-person" style="font-size: 3rem; color: #667eea;"></i>
                        <h5 class="mt-3">Patient</h5>
                        <a href="@Url.Action("Login", "Account", new { userType = "patient" })" class="btn btn-primary">Patient Login</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- About Section -->
    <div class="container my-5">
        <div class="row">
            <div class="col-md-12">
                <h2 class="text-center mb-4">About MediCare</h2>
                <p class="text-center">
                    MediCare Pvt Ltd is a leading private healthcare provider in Sri Lanka, committed to delivering
                    exceptional medical services. With multiple clinics and medical centers across the country, we
                    specialize in general medicine, pediatrics, cardiology, and dermatology. Our online appointment
                    system makes it easier than ever to access quality healthcare.
                </p>
            </div>
        </div>
    </div>

</body>
</html>