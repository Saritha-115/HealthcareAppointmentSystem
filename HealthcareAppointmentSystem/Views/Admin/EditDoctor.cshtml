@model HealthcareAppointmentSystem.Models.Doctor

@{
    ViewData["Title"] = "Edit Doctor";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-10 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4><i class="bi bi-pencil"></i> Edit Doctor</h4>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb bg-transparent mb-0">
                            <li class="breadcrumb-item"><a href="@Url.Action("Dashboard")" class="text-white">Dashboard</a></li>
                            <li class="breadcrumb-item"><a href="@Url.Action("ManageDoctors")" class="text-white">Doctors</a></li>
                            <li class="breadcrumb-item active text-white">Edit Doctor</li>
                        </ol>
                    </nav>
                </div>
                <div class="card-body p-4">
                    <form method="post" asp-action="EditDoctor" asp-route-id="@Model.Id">
                        @if (ViewData.ModelState.ErrorCount > 0)
                        {
                            <div class="alert alert-danger">
                                @Html.ValidationSummary(false)
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Full Name</label>
                                <input asp-for="FullName" class="form-control" required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Email</label>
                                <input asp-for="Email" type="email" class="form-control" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Password</label>
                                <input asp-for="Password" type="password" class="form-control" />
                                <small class="text-muted">Leave blank to keep current password</small>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Phone Number</label>
                                <input asp-for="PhoneNumber" class="form-control" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Specialty</label>
                                <select asp-for="Specialty" class="form-control" required>
                                    <option value="">Select Specialty</option>
                                    @if (ViewBag.Specialties != null)
                                    {
                                        foreach (var specialty in ViewBag.Specialties)
                                        {
                                            <option value="@specialty.Name">@specialty.Name</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Qualification</label>
                                <input asp-for="Qualification" class="form-control" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Location</label>
                                <input asp-for="Location" class="form-control" required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Consultation Fee (LKR)</label>
                                <input asp-for="ConsultationFee" type="number" step="0.01" class="form-control" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label class="form-check-label" asp-for="IsActive">
                                    Active (Doctor can login and receive appointments)
                                </label>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="@Url.Action("ManageDoctors")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Update Doctor
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}