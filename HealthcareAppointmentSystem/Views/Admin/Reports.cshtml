@model List<HealthcareAppointmentSystem.Models.Appointment>

@{
    ViewData["Title"] = "Reports";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-graph-up"></i> System Reports</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Dashboard")">Dashboard</a></li>
                    <li class="breadcrumb-item active">Reports</li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- Statistics Summary -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-info text-white shadow">
                <div class="card-body text-center">
                    <h2>@ViewBag.TotalAppointments</h2>
                    <p class="mb-0">Total Appointments</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white shadow">
                <div class="card-body text-center">
                    <h2>@ViewBag.CompletedAppointments</h2>
                    <p class="mb-0">Completed</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white shadow">
                <div class="card-body text-center">
                    <h2>@ViewBag.PendingAppointments</h2>
                    <p class="mb-0">Pending</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white shadow">
                <div class="card-body text-center">
                    <h2>@ViewBag.CancelledAppointments</h2>
                    <p class="mb-0">Cancelled</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Revenue Report -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-currency-dollar"></i> Revenue Summary</h5>
                </div>
                <div class="card-body">
                    <h3 class="text-success">LKR @ViewBag.TotalRevenue?.ToString("N2")</h3>
                    <p class="text-muted">Total Revenue from Paid Appointments</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-people"></i> User Statistics</h5>
                </div>
                <div class="card-body">
                    <p><strong>Total Doctors:</strong> @ViewBag.TotalDoctors</p>
                    <p><strong>Total Patients:</strong> @ViewBag.TotalPatients</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Appointments by Specialty -->
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-pie-chart"></i> Appointments by Specialty</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.AppointmentsBySpecialty != null)
                    {
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Specialty</th>
                                        <th>Number of Appointments</th>
                                        <th>Percentage</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in ViewBag.AppointmentsBySpecialty)
                                    {
                                        var percentage = (item.Count * 100.0) / ViewBag.TotalAppointments;
                                        <tr>
                                            <td><span class="badge bg-primary">@item.Specialty</span></td>
                                            <td>@item.Count</td>
                                            <td>
                                                <div class="progress" style="height: 20px;">
                                                    <div class="progress-bar" role="progressbar" style="width: @percentage%;" aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100">
                                                        @percentage.ToString("F1")%
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>