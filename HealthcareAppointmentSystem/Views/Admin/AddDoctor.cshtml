@{
}
@model HealthcareAppointmentSystem.Models.Doctor

@{
    ViewData["Title"] = "Add New Doctor";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-10 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4><i class="bi bi-person-plus"></i> Add New Doctor</h4>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb bg-transparent mb-0">
                            <li class="breadcrumb-item"><a href="@Url.Action("Dashboard")" class="text-white">Dashboard</a></li>
                            <li class="breadcrumb-item"><a href="@Url.Action("ManageDoctors")" class="text-white">Doctors</a></li>
                            <li class="breadcrumb-item active text-white">Add Doctor</li>
                        </ol>
                    </nav>
                </div>
                <div class="card-body p-4">
                    <form method="post" asp-action="AddDoctor">
                        @if (ViewData.ModelState.ErrorCount > 0)
                        {
                            <div class="alert alert-danger">
                                <i class="bi bi-exclamation-triangle"></i>
                                @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Full Name <span class="text-danger">*</span></label>
                                <input asp-for="FullName" class="form-control" placeholder="Dr. John Smith" required />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Email <span class="text-danger">*</span></label>
                                <input asp-for="Email" type="email" class="form-control" placeholder="doctor@medicare.lk" required />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Password <span class="text-danger">*</span></label>
                                <input asp-for="Password" type="password" class="form-control" placeholder="Temporary password" required />
                                <span asp-validation-for="Password" class="text-danger"></span>
                                <small class="text-muted">Doctor can change this after first login</small>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Phone Number <span class="text-danger">*</span></label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="+94771234567" required />
                                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Specialty <span class="text-danger">*</span></label>
                                <select asp-for="Specialty" class="form-control" required>
                                    <option value="">Select Specialty</option>
                                    @if (ViewBag.Specialties != null)
                                    {
                                        foreach (var specialty in ViewBag.Specialties)
                                        {
                                            <option value="@specialty.Name">@specialty.Name</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="Specialty" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Qualification <span class="text-danger">*</span></label>
                                <input asp-for="Qualification" class="form-control" placeholder="MBBS, MD" required />
                                <span asp-validation-for="Qualification" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Location <span class="text-danger">*</span></label>
                                <input asp-for="Location" class="form-control" placeholder="Colombo" required />
                                <span asp-validation-for="Location" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Consultation Fee (LKR) <span class="text-danger">*</span></label>
                                <input asp-for="ConsultationFee" type="number" step="0.01" class="form-control" placeholder="2500.00" required />
                                <span asp-validation-for="ConsultationFee" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="@Url.Action("ManageDoctors")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Add Doctor
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}