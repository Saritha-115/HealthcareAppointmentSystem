@model List<HealthcareAppointmentSystem.Models.Patient>

@{
    ViewData["Title"] = "View Patients";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-people"></i> All Patients</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Dashboard")">Dashboard</a></li>
                    <li class="breadcrumb-item active">Patients</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-header bg-white">
            <h5 class="mb-0">Registered Patients (@Model.Count)</h5>
        </div>
        <div class="card-body">
            @if (Model.Count == 0)
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox" style="font-size: 4rem; color: #ccc;"></i>
                    <p class="text-muted mt-3">No patients registered yet.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Gender</th>
                                <th>Blood Group</th>
                                <th>Date of Birth</th>
                                <th>Registered On</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var patient in Model)
                            {
                                <tr>
                                    <td><strong>@patient.FullName</strong></td>
                                    <td>@patient.Email</td>
                                    <td>@patient.PhoneNumber</td>
                                    <td>@patient.Gender</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(patient.BloodGroup))
                                        {
                                            <span class="badge bg-danger">@patient.BloodGroup</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </td>
                                    <td>@patient.DateOfBirth.ToString("dd MMM yyyy")</td>
                                    <td>@patient.CreatedAt.ToString("dd MMM yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>