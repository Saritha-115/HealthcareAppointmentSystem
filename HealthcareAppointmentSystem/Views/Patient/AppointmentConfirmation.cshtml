@model HealthcareAppointmentSystem.Models.Appointment

@{
    ViewData["Title"] = "Appointment Confirmed";
}

<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-body text-center p-5">
                    <div class="text-success mb-4">
                        <i class="bi bi-check-circle-fill" style="font-size: 6rem;"></i>
                    </div>

                    <h2 class="text-success mb-3">Appointment Confirmed!</h2>
                    <p class="lead">Your appointment has been successfully booked and payment received.</p>

                    <hr class="my-4">

                    <div class="text-start">
                        <h5 class="mb-3"><i class="bi bi-calendar-check"></i> Appointment Details</h5>

                        <div class="row mb-2">
                            <div class="col-md-4"><strong>Doctor:</strong></div>
                            <div class="col-md-8">@Model.DoctorName</div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-md-4"><strong>Specialty:</strong></div>
                            <div class="col-md-8"><span class="badge bg-primary">@Model.Specialty</span></div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-md-4"><strong>Date:</strong></div>
                            <div class="col-md-8">@Model.AppointmentDate.ToString("dddd, dd MMMM yyyy")</div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-md-4"><strong>Time:</strong></div>
                            <div class="col-md-8">@Model.AppointmentTime</div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-md-4"><strong>Consultation Fee:</strong></div>
                            <div class="col-md-8">LKR @Model.ConsultationFee.ToString("N2")</div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-md-4"><strong>Payment Status:</strong></div>
                            <div class="col-md-8">
                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Paid</span>
                            </div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-md-4"><strong>Booking ID:</strong></div>
                            <div class="col-md-8"><code>@Model.Id</code></div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-md-4"><strong>Status:</strong></div>
                            <div class="col-md-8">
                                <span class="badge bg-info">@Model.Status</span>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="alert alert-info text-start">
                        <h6><i class="bi bi-info-circle"></i> Important Information</h6>
                        <ul class="mb-0">
                            <li>Please arrive 10 minutes before your appointment time</li>
                            <li>Bring any relevant medical documents or test results</li>
                            <li>You will receive a confirmation email shortly</li>
                            <li>If you need to reschedule, please do so at least 24 hours in advance</li>
                        </ul>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <a href="@Url.Action("MyAppointments")" class="btn btn-primary btn-lg">
                            <i class="bi bi-calendar-event"></i> View My Appointments
                        </a>
                        <a href="@Url.Action("Dashboard")" class="btn btn-outline-secondary">
                            <i class="bi bi-house"></i> Go to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>