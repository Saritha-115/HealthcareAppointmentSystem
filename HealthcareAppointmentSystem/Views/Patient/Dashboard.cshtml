@model List<HealthcareAppointmentSystem.Models.Appointment>

@{
    ViewData["Title"] = "Patient Dashboard";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-speedometer2"></i> Patient Dashboard</h2>
            <p class="text-muted">Welcome back, @User.Identity.Name</p>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card bg-primary text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-1">Upcoming Appointments</h6>
                            <h2 class="mb-0">@ViewBag.UpcomingCount</h2>
                        </div>
                        <div class="text-white-50">
                            <i class="bi bi-calendar-check" style="font-size: 3rem;"></i>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="@Url.Action("MyAppointments")" class="text-white text-decoration-none">
                        View All <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card bg-success text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-1">Completed</h6>
                            <h2 class="mb-0">@ViewBag.CompletedCount</h2>
                        </div>
                        <div class="text-white-50">
                            <i class="bi bi-check-circle" style="font-size: 3rem;"></i>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="@Url.Action("MedicalRecords")" class="text-white text-decoration-none">
                        View Records <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card bg-info text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-1">Total Appointments</h6>
                            <h2 class="mb-0">@ViewBag.TotalAppointments</h2>
                        </div>
                        <div class="text-white-50">
                            <i class="bi bi-calendar3" style="font-size: 3rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-lightning-charge"></i> Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-3 mb-3">
                            <a href="@Url.Action("SearchDoctors")" class="btn btn-outline-primary btn-lg w-100">
                                <i class="bi bi-search"></i><br>
                                Find a Doctor
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a href="@Url.Action("MyAppointments")" class="btn btn-outline-success btn-lg w-100">
                                <i class="bi bi-calendar-event"></i><br>
                                My Appointments
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a href="@Url.Action("MedicalRecords")" class="btn btn-outline-info btn-lg w-100">
                                <i class="bi bi-file-medical"></i><br>
                                Medical Records
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a href="@Url.Action("Profile")" class="btn btn-outline-warning btn-lg w-100">
                                <i class="bi bi-person"></i><br>
                                My Profile
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Upcoming Appointments -->
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-calendar-event"></i> Upcoming Appointments</h5>
                </div>
                <div class="card-body">
                    @if (Model.Count == 0)
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-calendar-x" style="font-size: 4rem; color: #ccc;"></i>
                            <p class="text-muted mt-3">No upcoming appointments.</p>
                            <a href="@Url.Action("SearchDoctors")" class="btn btn-primary">
                                <i class="bi bi-search"></i> Find a Doctor
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var appointment in Model)
                            {
                                <div class="list-group-item">
                                    <div class="row align-items-center">
                                        <div class="col-md-3">
                                            <h6 class="mb-1">@appointment.DoctorName</h6>
                                            <small class="text-muted">@appointment.Specialty</small>
                                        </div>
                                        <div class="col-md-3">
                                            <i class="bi bi-calendar"></i> @appointment.AppointmentDate.ToString("dd MMM yyyy")<br>
                                            <i class="bi bi-clock"></i> @appointment.AppointmentTime
                                        </div>
                                        <div class="col-md-2">
                                            @switch (appointment.Status)
                                            {
                                                case "Pending":
                                                    <span class="badge bg-warning">Pending</span>
                                                    break;
                                                case "Confirmed":
                                                    <span class="badge bg-success">Confirmed</span>
                                                    break;
                                                default:
                                                    <span class="badge bg-secondary">@appointment.Status</span>
                                                    break;
                                            }
                                        </div>
                                        <div class="col-md-2">
                                            LKR @appointment.ConsultationFee.ToString("N2")
                                        </div>
                                        <div class="col-md-2 text-end">
                                            <a href="@Url.Action("AppointmentDetails", new { id = appointment.Id })" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye"></i> View
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>