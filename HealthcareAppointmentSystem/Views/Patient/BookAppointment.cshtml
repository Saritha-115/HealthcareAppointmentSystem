@{
    ViewData["Title"] = "Book Appointment";
    var doctor = ViewBag.Doctor as HealthcareAppointmentSystem.Models.Doctor;
    var patient = ViewBag.Patient as HealthcareAppointmentSystem.Models.Patient;
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4><i class="bi bi-calendar-plus"></i> Book Appointment</h4>
                </div>
                <div class="card-body p-4">
                    
                    <!-- Doctor Info Summary -->
                    <div class="alert alert-info">
                        <h5>@doctor.FullName</h5>
                        <p class="mb-0">
                            <span class="badge bg-primary">@doctor.Specialty</span> | 
                            <i class="bi bi-geo-alt"></i> @doctor.Location | 
                            <strong>Fee: LKR @doctor.ConsultationFee.ToString("N2")</strong>
                        </p>
                    </div>

                    <form method="post" asp-action="ConfirmBooking">
                        <input type="hidden" name="doctorId" value="@doctor.Id" />

                        <div class="mb-4">
                            <label class="form-label"><i class="bi bi-person"></i> Patient Name</label>
                            <input type="text" class="form-control" value="@patient.FullName" readonly />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label"><i class="bi bi-calendar"></i> Appointment Date <span class="text-danger">*</span></label>
                                <input type="date" name="appointmentDate" class="form-control" 
                                       min="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                                <small class="text-muted">Select a date (today or future)</small>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label"><i class="bi bi-clock"></i> Appointment Time <span class="text-danger">*</span></label>
                                <select name="appointmentTime" class="form-control" required>
                                    <option value="">Select Time</option>
                                    <option value="09:00 AM">09:00 AM</option>
                                    <option value="10:00 AM">10:00 AM</option>
                                    <option value="11:00 AM">11:00 AM</option>
                                    <option value="12:00 PM">12:00 PM</option>
                                    <option value="01:00 PM">01:00 PM</option>
                                    <option value="02:00 PM">02:00 PM</option>
                                    <option value="03:00 PM">03:00 PM</option>
                                    <option value="04:00 PM">04:00 PM</option>
                                    <option value="05:00 PM">05:00 PM</option>
                                </select>
                            </div>
                        </div>

                        <!-- Available Days Info -->
                        @if (doctor.AvailabilitySchedule != null && doctor.AvailabilitySchedule.Any(a => a.IsAvailable))
                        {
                            <div class="alert alert-warning">
                                <strong><i class="bi bi-info-circle"></i> Doctor's Available Days:</strong><br>
                                @foreach (var schedule in doctor.AvailabilitySchedule.Where(a => a.IsAvailable))
                                {
                                    <span class="badge bg-success me-1">@schedule.DayOfWeek (@schedule.StartTime - @schedule.EndTime)</span>
                                }
                            </div>
                        }

                        <div class="alert alert-info">
                            <h6><i class="bi bi-currency-dollar"></i> Payment Summary</h6>
                            <p class="mb-0">Consultation Fee: <strong>LKR @doctor.ConsultationFee.ToString("N2")</strong></p>
                            <small class="text-muted">Payment will be processed in the next step</small>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="@Url.Action("DoctorDetails", new { id = doctor.Id })" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle"></i> Confirm Booking
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>