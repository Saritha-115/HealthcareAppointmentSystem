@model List<HealthcareAppointmentSystem.Models.Appointment>

@{
    ViewData["Title"] = "Medical Records";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-file-medical"></i> My Medical Records</h2>
            <p class="text-muted">View your consultation history and prescriptions</p>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="card shadow">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox" style="font-size: 4rem; color: #ccc;"></i>
                <p class="text-muted mt-3">No medical records found. Complete an appointment to see your records here.</p>
                <a href="@Url.Action("SearchDoctors")" class="btn btn-primary">
                    <i class="bi bi-search"></i> Find a Doctor
                </a>
            </div>
        </div>
    }
    else
    {
        @foreach (var record in Model)
        {
            <div class="card shadow mb-4">
                <div class="card-header bg-success text-white">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h5 class="mb-0">
                                <i class="bi bi-calendar-check"></i>
                                @record.AppointmentDate.ToString("dd MMMM yyyy") - @record.AppointmentTime
                            </h5>
                        </div>
                        <div class="col-md-4 text-end">
                            <span class="badge bg-light text-dark">@record.Specialty</span>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted mb-1">Doctor</h6>
                            <p class="mb-0"><strong>@record.DoctorName</strong></p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted mb-1">Consultation Fee</h6>
                            <p class="mb-0">LKR @record.ConsultationFee.ToString("N2")</p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(record.ConsultationNotes))
                    {
                        <div class="mb-3">
                            <h6 class="text-muted mb-2"><i class="bi bi-clipboard-pulse"></i> Consultation Notes</h6>
                            <div class="alert alert-light mb-0">
                                @record.ConsultationNotes
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(record.Prescription))
                    {
                        <div class="mb-3">
                            <h6 class="text-muted mb-2"><i class="bi bi-prescription2"></i> Prescription</h6>
                            <div class="alert alert-warning mb-0">
                                @record.Prescription
                            </div>
                        </div>
                    }

                    <div class="text-end mt-3">
                        <a href="@Url.Action("AppointmentDetails", new { id = record.Id })" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-eye"></i> View Full Details
                        </a>
                    </div>
                </div>
            </div>
        }
    }
</div>