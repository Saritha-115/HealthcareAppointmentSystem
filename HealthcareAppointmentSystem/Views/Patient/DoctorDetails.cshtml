@model HealthcareAppointmentSystem.Models.Doctor

@{
    ViewData["Title"] = "Doctor Details";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <!-- Doctor Info Card -->
            <div class="card shadow">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <i class="bi bi-person-circle" style="font-size: 6rem; color: #667eea;"></i>
                        <h2 class="mt-3">@Model.FullName</h2>
                        <p class="text-muted h5">@Model.Qualification</p>
                        <span class="badge bg-primary fs-6">@Model.Specialty</span>
                    </div>

                    <hr>

                    <div class="row text-center mb-4">
                        <div class="col-md-4">
                            <i class="bi bi-geo-alt text-primary" style="font-size: 2rem;"></i>
                            <p class="mb-0"><strong>Location</strong></p>
                            <p class="text-muted">@Model.Location</p>
                        </div>
                        <div class="col-md-4">
                            <i class="bi bi-telephone text-primary" style="font-size: 2rem;"></i>
                            <p class="mb-0"><strong>Phone</strong></p>
                            <p class="text-muted">@Model.PhoneNumber</p>
                        </div>
                        <div class="col-md-4">
                            <i class="bi bi-currency-dollar text-primary" style="font-size: 2rem;"></i>
                            <p class="mb-0"><strong>Consultation Fee</strong></p>
                            <p class="text-muted">LKR @Model.ConsultationFee.ToString("N2")</p>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <a href="@Url.Action("BookAppointment", new { doctorId = Model.Id })" class="btn btn-primary btn-lg">
                            <i class="bi bi-calendar-plus"></i> Book Appointment
                        </a>
                    </div>
                </div>
            </div>

            <!-- Availability Schedule -->
            @if (Model.AvailabilitySchedule != null && Model.AvailabilitySchedule.Any(a => a.IsAvailable))
            {
                <div class="card shadow mt-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-clock"></i> Availability Schedule</h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            @foreach (var schedule in Model.AvailabilitySchedule.Where(a => a.IsAvailable))
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><strong>@schedule.DayOfWeek</strong></span>
                                    <span class="badge bg-success">@schedule.StartTime - @schedule.EndTime</span>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }

            <!-- Patient Reviews -->
            <div class="card shadow mt-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-star-fill text-warning"></i> Patient Reviews</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.Feedback != null && ((List<HealthcareAppointmentSystem.Models.Feedback>)ViewBag.Feedback).Count > 0)
                    {
                        <div class="mb-3">
                            <h4>
                                Average Rating:
                                <span class="text-warning">
                                    @for (int i = 0; i < (int)ViewBag.AverageRating; i++)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }
                                    @for (int i = (int)ViewBag.AverageRating; i < 5; i++)
                                    {
                                        <i class="bi bi-star"></i>
                                    }
                                </span>
                                (@ViewBag.AverageRating.ToString("F1"))
                            </h4>
                        </div>

                        @foreach (var feedback in (List<HealthcareAppointmentSystem.Models.Feedback>)ViewBag.Feedback)
                        {
                            <div class="mb-3 pb-3 border-bottom">
                                <div class="d-flex justify-content-between">
                                    <strong>@feedback.PatientName</strong>
                                    <small class="text-muted">@feedback.CreatedAt.ToString("dd MMM yyyy")</small>
                                </div>
                                <div class="text-warning mb-1">
                                    @for (int i = 0; i < feedback.Rating; i++)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }
                                    @for (int i = feedback.Rating; i < 5; i++)
                                    {
                                        <i class="bi bi-star"></i>
                                    }
                                </div>
                                <p class="mb-0">@feedback.Comments</p>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No reviews yet.</p>
                    }
                </div>
            </div>

            <div class="mt-4">
                <a href="@Url.Action("SearchDoctors")" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Search
                </a>
            </div>
        </div>
    </div>
</div>