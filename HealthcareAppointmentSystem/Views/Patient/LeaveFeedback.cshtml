@{
    ViewData["Title"] = "Leave Feedback";
    var appointment = ViewBag.Appointment as HealthcareAppointmentSystem.Models.Appointment;
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4><i class="bi bi-star"></i> Leave Feedback</h4>
                </div>
                <div class="card-body p-4">

                    <div class="alert alert-info">
                        <h6>Appointment with @appointment.DoctorName</h6>
                        <p class="mb-0">
                            <strong>Date:</strong> @appointment.AppointmentDate.ToString("dd MMMM yyyy") |
                            <strong>Specialty:</strong> @appointment.Specialty
                        </p>
                    </div>

                    <form method="post" asp-action="SubmitFeedback">
                        <input type="hidden" name="appointmentId" value="@appointment.Id" />

                        <div class="mb-4">
                            <label class="form-label">Rating <span class="text-danger">*</span></label>
                            <div class="rating-stars">
                                <div class="star-rating">
                                    <input type="radio" name="rating" value="5" id="star5" required />
                                    <label for="star5" title="5 stars">★</label>

                                    <input type="radio" name="rating" value="4" id="star4" />
                                    <label for="star4" title="4 stars">★</label>

                                    <input type="radio" name="rating" value="3" id="star3" />
                                    <label for="star3" title="3 stars">★</label>

                                    <input type="radio" name="rating" value="2" id="star2" />
                                    <label for="star2" title="2 stars">★</label>

                                    <input type="radio" name="rating" value="1" id="star1" />
                                    <label for="star1" title="1 star">★</label>
                                </div>
                            </div>
                            <small class="text-muted">Click on the stars to rate</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Your Comments</label>
                            <textarea name="comments" class="form-control" rows="5"
                                      placeholder="Share your experience with the doctor..."></textarea>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("MyAppointments")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send"></i> Submit Feedback
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .star-rating {
        direction: rtl;
        display: inline-flex;
        font-size: 3rem;
    }

        .star-rating input[type="radio"] {
            display: none;
        }

        .star-rating label {
            color: #ddd;
            cursor: pointer;
            padding: 0 5px;
        }

            .star-rating input[type="radio"]:checked ~ label,
            .star-rating label:hover,
            .star-rating label:hover ~ label {
                color: #ffc107;
            }
</style>