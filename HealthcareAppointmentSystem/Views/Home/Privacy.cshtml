@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-lg-10 mx-auto">
            <h1 class="display-4 mb-4">Privacy Policy</h1>
            <p class="text-muted mb-5"><strong>Last Updated:</strong> November 2024</p>

            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i>
                <strong>Important:</strong> Your privacy is important to us. This policy explains how we collect,
                use, and protect your personal information.
            </div>

            <!-- Introduction -->
            <section class="mb-5">
                <h2>1. Introduction</h2>
                <p>
                    Welcome to MediCare Connect ("we," "our," or "us"). This Privacy Policy explains how we collect,
                    use, disclose, and safeguard your information when you use our Online Healthcare Appointment System.
                    Please read this privacy policy carefully. If you do not agree with the terms of this privacy policy,
                    please do not access the platform.
                </p>
            </section>

            <!-- Information We Collect -->
            <section class="mb-5">
                <h2>2. Information We Collect</h2>

                <h4 class="mt-4">2.1 Personal Information</h4>
                <p>We collect personal information that you voluntarily provide when you:</p>
                <ul>
                    <li>Register for an account</li>
                    <li>Book an appointment</li>
                    <li>Make a payment</li>
                    <li>Contact us for support</li>
                </ul>
                <p>This information may include:</p>
                <ul>
                    <li>Full name</li>
                    <li>Email address</li>
                    <li>Phone number</li>
                    <li>Date of birth</li>
                    <li>Gender</li>
                    <li>Residential address</li>
                    <li>Blood group</li>
                    <li>Medical history</li>
                </ul>

                <h4 class="mt-4">2.2 Medical Information</h4>
                <p>With your consent, we collect and store:</p>
                <ul>
                    <li>Consultation notes from doctors</li>
                    <li>Prescriptions and treatment plans</li>
                    <li>Medical test results</li>
                    <li>Appointment history</li>
                </ul>

                <h4 class="mt-4">2.3 Payment Information</h4>
                <p>
                    When you make a payment, we collect payment card information through our secure payment gateway.
                    We do not store complete credit card details on our servers.
                </p>

                <h4 class="mt-4">2.4 Technical Information</h4>
                <p>We automatically collect:</p>
                <ul>
                    <li>IP address</li>
                    <li>Browser type and version</li>
                    <li>Device information</li>
                    <li>Operating system</li>
                    <li>Access times and dates</li>
                    <li>Pages viewed and features used</li>
                </ul>
            </section>

            <!-- How We Use Your Information -->
            <section class="mb-5">
                <h2>3. How We Use Your Information</h2>
                <p>We use the information we collect to:</p>

                <div class="card mb-3">
                    <div class="card-body">
                        <h5><i class="bi bi-check-circle text-success"></i> Provide Services</h5>
                        <p class="mb-0">
                            Create and manage your account, process appointments, facilitate consultations,
                            and maintain medical records.
                        </p>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-body">
                        <h5><i class="bi bi-check-circle text-success"></i> Process Payments</h5>
                        <p class="mb-0">
                            Handle consultation fees, generate receipts, and process refunds when applicable.
                        </p>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-body">
                        <h5><i class="bi bi-check-circle text-success"></i> Communicate With You</h5>
                        <p class="mb-0">
                            Send appointment confirmations, reminders, updates about your healthcare,
                            and respond to your inquiries.
                        </p>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-body">
                        <h5><i class="bi bi-check-circle text-success"></i> Improve Our Services</h5>
                        <p class="mb-0">
                            Analyze usage patterns, conduct research, and develop new features to enhance
                            user experience.
                        </p>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-body">
                        <h5><i class="bi bi-check-circle text-success"></i> Ensure Security</h5>
                        <p class="mb-0">
                            Protect against fraud, unauthorized access, and other security threats.
                        </p>
                    </div>
                </div>
            </section>

            <!-- Information Sharing -->
            <section class="mb-5">
                <h2>4. Information Sharing and Disclosure</h2>
                <p>We do not sell your personal information. We may share your information with:</p>

                <h4 class="mt-4">4.1 Healthcare Providers</h4>
                <p>
                    Your medical information is shared with doctors you book appointments with to facilitate
                    proper healthcare delivery.
                </p>

                <h4 class="mt-4">4.2 Service Providers</h4>
                <p>
                    We may share information with third-party service providers who help us operate our platform,
                    such as payment processors, hosting providers, and analytics services.
                </p>

                <h4 class="mt-4">4.3 Legal Requirements</h4>
                <p>
                    We may disclose your information if required by law, court order, or government regulations.
                </p>

                <h4 class="mt-4">4.4 Business Transfers</h4>
                <p>
                    In the event of a merger, acquisition, or sale of assets, your information may be transferred
                    to the new entity.
                </p>
            </section>

            <!-- Data Security -->
            <section class="mb-5">
                <h2>5. Data Security</h2>
                <p>We implement industry-standard security measures to protect your information:</p>
                <ul>
                    <li><strong>Encryption:</strong> All data transmitted between your device and our servers is encrypted using SSL/TLS</li>
                    <li><strong>Secure Storage:</strong> Data is stored in secure, encrypted databases</li>
                    <li><strong>Access Controls:</strong> Strict access controls limit who can view your information</li>
                    <li><strong>Regular Audits:</strong> We conduct regular security audits and updates</li>
                    <li><strong>Monitoring:</strong> Continuous monitoring for suspicious activities</li>
                </ul>
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle"></i>
                    <strong>Note:</strong> While we take reasonable measures to protect your information, no method
                    of transmission over the internet is 100% secure.
                </div>
            </section>

            <!-- Your Rights -->
            <section class="mb-5">
                <h2>6. Your Rights and Choices</h2>
                <p>You have the following
