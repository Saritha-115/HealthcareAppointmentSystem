@{
    ViewData["Title"] = "About Us";
}

<div class="container mt-5 mb-5">
    <!-- Hero Section -->
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-4 mb-3">About MediCare Connect</h1>
            <p class="lead text-muted">Your trusted partner in healthcare management</p>
        </div>
    </div>

    <!-- Company Overview -->
    <div class="row mb-5">
        <div class="col-md-6">
            <img src="~/images/about.png"
                 class="img-fluid rounded shadow" alt="MediCare" />
        </div>
        <div class="col-md-6 d-flex align-items-center">
            <div>
                <h2 class="mb-4">Who We Are</h2>
                <p>
                    MediCare Pvt Ltd is a leading private healthcare provider in Sri Lanka, dedicated to
                    delivering exceptional medical services to our community. Established with a vision to
                    make quality healthcare accessible to everyone, we have grown to become one of the most
                    trusted names in the healthcare industry.
                </p>
                <p>
                    With multiple clinics and medical centers across Sri Lanka, we provide comprehensive
                    healthcare services in various specialties including General Medicine, Pediatrics,
                    Cardiology, Dermatology, Orthopedics, and ENT care.
                </p>
            </div>
        </div>
    </div>

    <!-- Mission & Vision -->
    <div class="row mb-5">
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow border-0">
                <div class="card-body p-4">
                    <div class="text-center mb-3">
                        <i class="bi bi-bullseye" style="font-size: 3rem; color: #667eea;"></i>
                    </div>
                    <h3 class="text-center mb-3">Our Mission</h3>
                    <p class="text-center">
                        To provide accessible, affordable, and quality healthcare services to all our patients
                        through innovation, compassion, and excellence. We strive to improve the health and
                        wellbeing of our community by delivering patient-centered care.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow border-0">
                <div class="card-body p-4">
                    <div class="text-center mb-3">
                        <i class="bi bi-eye" style="font-size: 3rem; color: #667eea;"></i>
                    </div>
                    <h3 class="text-center mb-3">Our Vision</h3>
                    <p class="text-center">
                        To be the most trusted and preferred healthcare provider in Sri Lanka, recognized for
                        our commitment to excellence, innovation in healthcare delivery, and exceptional patient
                        outcomes. We envision a healthier Sri Lanka through our services.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Core Values -->
    <div class="row mb-5">
        <div class="col-12">
            <h2 class="text-center mb-5">Our Core Values</h2>
        </div>

        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card text-center h-100 border-0 shadow-sm">
                <div class="card-body">
                    <i class="bi bi-heart-pulse-fill text-primary" style="font-size: 3rem;"></i>
                    <h5 class="mt-3">Compassion</h5>
                    <p class="text-muted">We care deeply about every patient and their wellbeing</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card text-center h-100 border-0 shadow-sm">
                <div class="card-body">
                    <i class="bi bi-award-fill text-success" style="font-size: 3rem;"></i>
                    <h5 class="mt-3">Excellence</h5>
                    <p class="text-muted">We maintain the highest standards in everything we do</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card text-center h-100 border-0 shadow-sm">
                <div class="card-body">
                    <i class="bi bi-people-fill text-info" style="font-size: 3rem;"></i>
                    <h5 class="mt-3">Integrity</h5>
                    <p class="text-muted">We uphold honesty and ethical practices always</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card text-center h-100 border-0 shadow-sm">
                <div class="card-body">
                    <i class="bi bi-lightbulb-fill text-warning" style="font-size: 3rem;"></i>
                    <h5 class="mt-3">Innovation</h5>
                    <p class="text-muted">We embrace technology to improve patient care</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics -->
    <div class="row bg-light p-5 rounded mb-5">
        <div class="col-12 text-center mb-4">
            <h2>Our Impact</h2>
        </div>
        <div class="col-md-3 text-center mb-3">
            <h1 class="display-4 text-primary">10+</h1>
            <p class="text-muted">Years of Service</p>
        </div>
        <div class="col-md-3 text-center mb-3">
            <h1 class="display-4 text-primary">50+</h1>
            <p class="text-muted">Expert Doctors</p>
        </div>
        <div class="col-md-3 text-center mb-3">
            <h1 class="display-4 text-primary">10,000+</h1>
            <p class="text-muted">Patients Served</p>
        </div>
        <div class="col-md-3 text-center mb-3">
            <h1 class="display-4 text-primary">6</h1>
            <p class="text-muted">Specialties</p>
        </div>
    </div>

    <!-- Why Choose Us -->
    <div class="row mb-5">
        <div class="col-12">
            <h2 class="text-center mb-5">Why Choose MediCare Connect?</h2>
        </div>

        <div class="col-md-6 mb-4">
            <div class="d-flex">
                <div class="flex-shrink-0">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 2rem;"></i>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h5>Experienced Medical Professionals</h5>
                    <p class="text-muted">
                        Our team consists of highly qualified and experienced doctors across various specialties,
                        committed to providing the best care possible.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="d-flex">
                <div class="flex-shrink-0">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 2rem;"></i>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h5>Modern Technology</h5>
                    <p class="text-muted">
                        We utilize the latest medical technology and equipment to ensure accurate diagnosis
                        and effective treatment for our patients.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="d-flex">
                <div class="flex-shrink-0">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 2rem;"></i>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h5>Convenient Online Booking</h5>
                    <p class="text-muted">
                        Our digital platform makes it easy to book appointments, make payments, and access
                        your medical records from anywhere, anytime.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="d-flex">
                <div class="flex-shrink-0">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 2rem;"></i>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h5>Patient-Centered Care</h5>
                    <p class="text-muted">
                        We prioritize your comfort and wellbeing, ensuring personalized attention and
                        comprehensive care throughout your healthcare journey.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- CTA Section -->
    <div class="row">
        <div class="col-12">
            <div class="card bg-primary text-white text-center p-5 shadow">
                <div class="card-body">
                    <h2 class="mb-4">Ready to Experience Quality Healthcare?</h2>
                    <p class="lead mb-4">Book your appointment with our expert doctors today</p>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="@Url.Action("SearchDoctors", "Patient")" class="btn btn-light btn-lg">
                            <i class="bi bi-search"></i> Find a Doctor
                        </a>
                        <a href="@Url.Action("RegisterPatient", "Account")" class="btn btn-outline-light btn-lg">
                            <i class="bi bi-person-plus"></i> Register Now
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>